# VergeOS target + creds (demo values — change for your env)
VERGE_URL=https://your-vergeos-host
VERGE_USERNAME=your-username
VERGE_PASSWORD=your-password
WEB_LISTEN=:9888

# Exporter build inputs (matching GitHub Releases assets)
# Example tag: v1.1.9 -> set EXPORTER_VERSION=1.1.9
EXPORTER_VERSION=latest
# ARCH: x86_64 for Intel/AMD hosts; arm64 for Apple Silicon/Graviton, etc.
EXPORTER_ARCH=arm64

# Grafana admin password (change for prod)
GRAFANA_ADMIN_PASSWORD=admin
